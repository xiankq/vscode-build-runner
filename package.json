{
  "publisher": "Kaiqun",
  "name": "build-runner",
  "displayName": "Dart build_runner",
  "version": "4.0.2",
  "description": "A VS Code extension to quickly run Flutter/Dart build_runner.",
  "license": "MIT",
  "repository": "https://github.com/xiankq/vscode-build-runner",
  "keywords": [
    "flutter",
    "dart",
    "build_runner",
    "json_serializable",
    "freezed",
    "built_value",
    "flutter_mobx",
    "build runner",
    "generate",
    "generator"
  ],
  "categories": [
    "Other"
  ],
  "extensionDependencies": [
    "Dart-Code.dart-code"
  ],
  "main": "./dist/extension.js",
  "icon": "static/icon.png",
  "engines": {
    "vscode": "^1.118.0"
  },
  "activationEvents": [
    "onLanguage:dart",
    "workspaceContains:**/pubspec.yaml"
  ],
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "Build Runner",
      "properties": {
        "build_runner.fvm": {
          "type": "boolean",
          "default": false,
          "description": "Use FVM to run build_runner"
        },
        "build_runner.excludes": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Glob patterns to exclude from scanning"
        },
        "build_runner.args": {
          "type": "string",
          "default": "--delete-conflicting-outputs",
          "description": "Additional arguments passed to build_runner"
        }
      }
    },
    "commands": [
      {
        "category": "build-runner",
        "command": "build_runner.build",
        "title": "build",
        "icon": "$(play)"
      },
      {
        "category": "build-runner",
        "command": "build_runner.watch",
        "title": "watch",
        "icon": "$(sync)"
      },
      {
        "category": "build-runner",
        "command": "build_runner.refresh",
        "title": "Refresh",
        "icon": "$(refresh)"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "build_runner.watch",
          "when": "false"
        },
        {
          "command": "build_runner.build",
          "when": "false"
        }
      ],
      "view/item/context": [
        {
          "command": "build_runner.watch",
          "when": "view == build_runner_view && viewItem == file",
          "group": "inline"
        },
        {
          "command": "build_runner.build",
          "when": "view == build_runner_view && viewItem == file",
          "group": "inline"
        }
      ],
      "view/title": [
        {
          "command": "build_runner.refresh",
          "when": "view == build_runner_view",
          "group": "navigation"
        }
      ]
    },
    "views": {
      "explorer": [
        {
          "id": "build_runner_view",
          "name": "BUILD RUNNER",
          "when": "buildRunner.hasItems",
          "icon": "./static/icon.png"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run package",
    "compile": "pnpm run check-types && pnpm run lint && node esbuild.js",
    "watch": "npm-run-all -p watch:*",
    "watch:esbuild": "node esbuild.js --watch",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && node esbuild.js --production",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsc --noEmit",
    "lint": "eslint --fix",
    "test": "vscode-test",
    "release": "bumpp -r",
    "ci:build": "pnpm package && vsce package --no-dependencies",
    "ci:publish-vsce": "vsce publish --no-dependencies",
    "ci:publish-ovsx": "ovsx publish --no-dependencies"
  },
  "dependencies": {
    "@rollup/pluginutils": "^5.3.0",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.2.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.118.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.9.1",
    "bumpp": "^11.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^10.3.0",
    "eslint-plugin-format": "^2.0.1",
    "lint-staged": "^16.4.0",
    "npm-run-all": "^4.1.5",
    "ovsx": "^0.10.11",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^6.0.3"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged --concurrent false"
  }
}
